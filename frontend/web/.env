# ──────────────────────────────────────────────
# Super-App Environment Configuration
# ──────────────────────────────────────────────

# API
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_TIMEOUT=30000

# Auth
VITE_JWT_SECRET=super-app-jwt-secret-dev
VITE_JWT_EXPIRY=7d
VITE_REFRESH_TOKEN_EXPIRY=30d

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Razorpay
VITE_RAZORPAY_KEY_ID=
VITE_RAZORPAY_KEY_SECRET=

# Maps
VITE_GOOGLE_MAPS_API_KEY=

# WebSocket
VITE_WS_URL=ws://localhost:8000

# Feature Flags
VITE_ENABLE_AI_CHATBOT=true
VITE_ENABLE_VOICE_AGENT=false
VITE_ENABLE_REALTIME_TRACKING=true

# App
VITE_APP_NAME=Super-App
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development
