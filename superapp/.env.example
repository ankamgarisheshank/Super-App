# =============================================================
# SuperApp - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# ─── General ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=SuperApp
APP_URL=http://localhost:3000

# ─── Authentication ──────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# ─── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/superapp_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=superapp_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── MongoDB ─────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/superapp

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Elasticsearch ───────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_es_password

# ─── AI / LLM ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_ENVIRONMENT=us-east-1

# ─── Payments ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Storage (AWS S3 / compatible) ───────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
AWS_S3_BUCKET=superapp-assets

# ─── Notifications ───────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
FCM_SERVER_KEY=your_firebase_cloud_messaging_key

# ─── Maps ────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key
MAPBOX_ACCESS_TOKEN=your_mapbox_token

# ─── OAuth / Social Login ────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_secret

# ─── Observability ───────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
DATADOG_API_KEY=your_datadog_key
LOG_LEVEL=info

# ─── Turborepo Remote Cache (optional) ───────────────────────
TURBO_TOKEN=your_turbo_remote_cache_token
TURBO_TEAM=your_turbo_team_name
