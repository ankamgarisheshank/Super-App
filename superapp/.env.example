# GLOBAL CONFIG
PROJECT_NAME=SuperApp
ENVIRONMENT=development

# MONGODB CONFIG
MONGO_URI=mongodb://localhost:27017/superapp
MONGO_USER=root
MONGO_PASSWORD=password

# JWT CONFIG
JWT_SECRET=super-secret-key-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SERVICE PORTS
GATEWAY_PORT=8000
AUTH_PORT=8001
USER_PORT=8002
ECOMMERCE_PORT=8003
FOOD_PORT=8004
HEALTHCARE_PORT=8005
LOCAL_PORT=8006
RIDE_PORT=8007

# REDIS CONFIG (For caching and message broker)
REDIS_HOST=localhost
REDIS_PORT=6379

# THIRD PARTY APIS
STRIPE_API_KEY=sk_test_...
GOOGLE_MAPS_API_KEY=AIza...
TWILIO_SID=...
TWILIO_AUTH_TOKEN=...
