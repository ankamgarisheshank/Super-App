{
  "collection": "dark_stores",
  "fields": {
    "store_id": { "type": "String", "unique": true, "required": true },
    "name": { "type": "String", "required": true },
    "manager_id": { "type": "ObjectId", "ref": "users" },
    "location": {
      "address": { "type": "String" },
      "city": { "type": "String" },
      "pincode": { "type": "String" },
      "coordinates": { "lat": "Number", "lng": "Number" }
    },
    "service_radius_km": { "type": "Number" },
    "operational_status": { "type": "String", "enum": ["open", "closed", "maintenance"], "default": "open" },
    "timings": {
      "open": { "type": "String" },
      "close": { "type": "String" }
    },
    "sla_config": {
      "picking_limit_mins": { "type": "Number", "default": 5 },
      "delivery_promise_mins": { "type": "Number", "default": 15 }
    },
    "staff_ids": [{ "type": "ObjectId", "ref": "users" }]
  }
}
